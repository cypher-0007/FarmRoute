<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shipment</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
     <script src="https://cdn.tailwindcss.com"></script>
</head>
<style>
  * {
    font-family: montserrat;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
  }
</style>
  
<body>

    <section class=" flex items-center justify-center p-4">

    <div class="w-full max-w-md bg-white rounded-3xl shadow-sm p-6">

        <!-- Header -->

        <div class="flex items-center mb-8">
            <button class="mr-14 text-3xl font-bold">
                ←
            </button>

            <h1 class="text-2xl font-bold">
                Create Shipment
            </h1>
        </div>

        <!-- Form Starts Here -->

    </div>

</section>

   <!-- ====crops==== -->
<div class="mb-5">

    <label class="block text-sm font-medium text-gray-700 mb-2">
        Crop Type
    </label>

    <select
        class="w-full font-semibold border border-gray-300 rounded-xl p-4 bg-white focus:outline-none focus:ring-2 focus:ring-green-600">
        <option>🍅 Tomatoes</option>
        <option>🌽 Maize</option>
        <option>🍚 Rice</option>
        <option>🥔 Yam</option>

    </select>

</div>

     <!-- ====Quantity==== -->
<div class="mb-5">

    <label class="block text-sm font-medium text-gray-700 mb-2">
        Quantity
    </label>

    <div class="grid grid-cols-3 gap-3">

        <input
            type="number"
            placeholder="20"
            class="col-span-2 border border-gray-300 rounded-xl p-4 focus:outline-none focus:ring-2 focus:ring-green-600">

        <select
            class="border border-gray-300 rounded-xl p-4 focus:outline-none focus:ring-2 focus:ring-green-600">

            <option>Bags</option>
            <option>Tons</option>

        </select>

    </div>

</div>

   <!-- ===Location=== -->
<div class="mb-5">

    <label class="block text-sm font-medium text-gray-700 mb-2">
        Pickup Location
    </label>

    <select
        class="w-full border border-gray-300 font-semibold rounded-xl p-4 focus:outline-none focus:ring-2 focus:ring-green-600">

        <option>Makurdi, Benue</option>
        <option>Gboko, Benue</option>
        <option>Lokoja, Kogi</option>

    </select>

</div>

    <!-- ===market destination===  -->
<div class="mb-5">

    <label class="block text-sm font-medium text-gray-700 mb-2">
        Destination Market
    </label>

    <select
        class="w-full border border-gray-300 font-semibold rounded-xl p-4 focus:outline-none focus:ring-2 focus:ring-green-600">

        <option>Lagos Mile 12 Market</option>
        <option>Abuja Market</option>
        <option>Ibadan Market</option>

    </select>

</div>

     <!-- ===preferred date=== -->
<div class="mb-5">

    <label class="block text-sm font-medium text-gray-700 mb-2">
        Preferred Date
    </label>

    <input
        type="date"
        class="w-full border border-gray-300 font-semibold rounded-xl p-4 focus:outline-none focus:ring-2 focus:ring-green-600">

</div>

     <!-- ===Cost Estimate Card=== -->
<div class="bg-green-50 border border-green-100 rounded-xl p-5 mb-6">

    <p class="text-sm text-green-700">
        Estimated Cost Range
    </p>

    <h2 class="text-3xl font-bold text-green-700 mt-2">
        ₦18,000 - ₦22,000
    </h2>

    <p class="text-sm text-green-600 mt-1">
        per 50kg bag
    </p>

</div>

         <!-- ===Main Button=== -->
<button
    class="w-full bg-green-700 hover:bg-green-800 text-white py-4 rounded-xl font-semibold transition">

    Find Shared Transport

</button>       

</body>
</html>    